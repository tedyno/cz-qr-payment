{
  "name": "@tedyno/cz-qr-payment",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tedyno/cz-qr-payment.git"
  },
  "author": "tedyno <vanicekdave@gmail.com>",
  "version": "0.1.0",
  "description": "A simple CZ payment QR Code generator based on qrcode-svg & cdigit",
  "license": "MIT",
  "main": "dist/QRPaymentGenerator.js",
  "scripts": {
    "minify": "uglifyjs --compress --mangle -- src/qrsvgjs.js > dist/qrsvgjs.min.js",
    "build": "rm -fr dist/* && tsc"
  },
  "dependencies": {
    "cdigit": "^3.1.1",
    "qrcode-svg": "^1.1.0",
    "uglify-js": "^3.15.0"
  },
  "bugs": {
    "url": "https://github.com/tedyno/cz-qr-payment/issues"
  },
  "homepage": "https://github.com/tedyno/cz-qr-payment#readme",
  "devDependencies": {
    "@types/qrcode-svg": "^1.1.1",
    "@typescript-eslint/eslint-plugin": "^5.22.0",
    "@typescript-eslint/parser": "^5.22.0",
    "eslint": "^8.14.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.26.0",
    "tsc": "^2.0.4"
  },
  "keywords": [
    "qr",
    "payment",
    "czech",
    "cz"
  ]
}
